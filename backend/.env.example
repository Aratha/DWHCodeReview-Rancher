MSSQL_CONNECTION_STRING=
# LLM_CHAT_API=openai → .../v1/chat/completions + messages[]
# LLM_CHAT_API=api_v1_chat → .../api/v1/chat + system_prompt + input (örn. LM Studio)
LLM_CHAT_API=api_v1_chat
# api_v1_chat: kök http://host:port veya .../v1 (sondaki /v1 kaldırılıp /api/v1/chat eklenir)
# Örnek: curl http://localhost:1234/api/v1/chat -d '{"model":"...","system_prompt":"...","input":"..."}'
LLM_BASE_URL=http://localhost:1234/v1
LLM_CHAT_URL=
LLM_MODEL=openai/gpt-oss-120b
SQL_REVIEW_LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=
LLM_HTTP_TRUST_ENV=false
# İsteğe bağlı: LLM çağrılarında User-Agent (SIEM/DLP korelasyonu; boş bırakılırsa varsayılan kullanılır).
# LLM_HTTP_USER_AGENT=DWHCodeReview-Backend/1.0
LLM_ENFORCE_PRIVATE_NETWORK=true
# Virgülle ayrılmış istisna hostname listesi (gerekmedikçe boş bırakın)
LLM_ALLOW_PUBLIC_HOSTS=
# false: ham request/response loglanmaz (önerilen)
LLM_LOG_FULL_PAYLOADS=false
# LLM timeout riskini azaltmak icin eszamanli kural sayisini sinirlar (yerel LLM: 4–8).
SQL_REVIEW_MAX_CONCURRENT_RULES=6
# httpx okuma zaman asimi (saniye); ReadTimeout icin artirin veya SQL_REVIEW_MAX_CONCURRENT_RULES dusurun.
LLM_READ_TIMEOUT_SECONDS=900
# ReadTimeout/ConnectTimeout sonrasi ek deneme (0 = yok).
LLM_REQUEST_RETRIES=2
# SQL bu karakter uzunlugunu asarsa 2 parcali analiz devreye girer.
SQL_REVIEW_TWO_PART_THRESHOLD_CHARS=45000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Boş bırakılırsa API key zorunlu değil; doluysa /api uçlarında X-API-Key zorunlu.
API_ACCESS_TOKEN=
# Boş değilse /api/rules, /api/llm-config, /api/llm-logs uçlarında X-Admin-Key zorunlu.
API_ADMIN_TOKEN=
# Review endpointlerinde IP başına hız limiti.
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_REVIEW_MAX=30
