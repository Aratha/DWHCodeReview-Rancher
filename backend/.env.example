MSSQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=sqlserver.your-domain.local,1433;Database=YourDb;Trusted_Connection=yes;Encrypt=yes;TrustServerCertificate=yes;
# LLM_CHAT_API=openai -> .../v1/chat/completions + messages[]
# LLM_CHAT_API=api_v1_chat -> .../api/v1/chat + system_prompt + input
LLM_CHAT_API=api_v1_chat
# api_v1_chat icin kok URL (ornek: http://llm-service.ai.svc.cluster.local:1234/v1)
LLM_BASE_URL=http://llm-service.ai.svc.cluster.local:1234/v1
LLM_CHAT_URL=
LLM_MODEL=openai/gpt-oss-120b
SQL_REVIEW_LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=
LLM_HTTP_TRUST_ENV=false
# Istege bagli: LLM cagilarinda User-Agent
# LLM_HTTP_USER_AGENT=DWHCodeReview-Backend/1.0
LLM_ENFORCE_PRIVATE_NETWORK=true
# Virgulle ayrilmis istisna hostname listesi
LLM_ALLOW_PUBLIC_HOSTS=
# false: ham request/response loglanmaz
LLM_LOG_FULL_PAYLOADS=false
# LLM timeout riskini azaltmak icin eszamanli kural sayisini sinirlar
SQL_REVIEW_MAX_CONCURRENT_RULES=6
# httpx okuma zaman asimi (saniye)
LLM_READ_TIMEOUT_SECONDS=900
# ReadTimeout/ConnectTimeout sonrasi ek deneme (0 = yok)
LLM_REQUEST_RETRIES=2
# SQL bu karakter uzunlugunu asarsa 2 parcali analiz devreye girer
SQL_REVIEW_TWO_PART_THRESHOLD_CHARS=45000
CORS_ORIGINS=https://dwh.example.com
# Bos birakilirsa API key zorunlu degil; doluysa /api uclarinda X-API-Key zorunlu
API_ACCESS_TOKEN=
# Bos degilse /api/rules, /api/llm-config, /api/llm-logs uclarinda X-Admin-Key zorunlu
API_ADMIN_TOKEN=
# Review endpointlerinde IP basina hiz limiti
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_REVIEW_MAX=30
